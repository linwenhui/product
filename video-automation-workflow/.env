# 视频自动化工作流环境变量

# ============================================
# AI 脚本生成 - 使用当前 ClaudeCode 配置
# ============================================
# Claude API Base URL (当前环境的代理配置)
ANTHROPIC_BASE_URL=
CLAUDE_API_KEY=

# Claude API Key (代理模式下可选)
# CLAUDE_API_KEY=sk-ant-api03-...

# 模型选择 (可选)
CLAUDE_MODEL=qwen3.5-plus

# ============================================
# AI 画面生成 - 豆包 Seedream
# ============================================
ARK_API_KEY=
SEEDREAM_BASE_URL=
SEEDREAM_IMAGE_MODEL=doubao-seedream-4.0

# ============================================
# TTS 配音 - 使用当前代理配置
# ============================================
# 注意：TTS 代理需要浏览器 Cookie 认证，目前使用本地 TTS 备用方案
# OPENAI_BASE_URL=
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_API_KEY=proxy-mode

# ============================================
# 可选配置
# ============================================

# 背景音乐文件路径
# BGM_FILE=./assets/bgm.mp3
