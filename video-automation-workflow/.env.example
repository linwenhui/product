# 视频自动化工作流环境变量

# ============================================
# AI 脚本生成 - 使用当前 ClaudeCode 配置
# ============================================

# Claude API Base URL (当前环境的代理配置)
# 如果使用了代理或本地服务，设置此项
ANTHROPIC_BASE_URL=https://worklink.yealink.com/llmproxy/anthropic

# Claude API Key
# 如果使用了代理，可能不需要设置
# CLAUDE_API_KEY=sk-ant-api03-...

# 模型选择 (可选)
# 默认：claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# ============================================
# AI 画面生成 - 选择其中一个
# ============================================

# 豆包 Seedream (推荐，通过火山引擎 ARK)
ARK_API_KEY=your-ark-api-key
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_IMAGE_MODEL=doubao-seedream-4-0

# 或 FLUX (通过 inference.sh)
# 需要先运行 infsh login

# 或通义千问 DashScope
# DASHSCOPE_API_KEY=...

# ============================================
# TTS 配音 - Azure Cognitive Services
# ============================================
AZURE_API_KEY=your-azure-key
AZURE_REGION=eastasia

# ============================================
# 可选配置
# ============================================

# 背景音乐文件路径
# BGM_FILE=./assets/bgm.mp3
